generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIZATION (Tenant)
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  website     String?
  timezone    String   @default("Asia/Kolkata")
  plan        Plan     @default(TRIAL)
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          OrganizationMember[]
  whatsappAccounts WhatsappAccount[]
  contacts         Contact[]
  conversations    Conversation[]
  templates        MessageTemplate[]
  broadcasts       Broadcast[]
  chatbots         Chatbot[]
  automations      Automation[]
  apiKeys          ApiKey[]
  webhooks         WebhookEndpoint[]
  subscription     Subscription?
  teams            Team[]
  labels           Label[]
  quickReplies     QuickReply[]
  usageLogs        UsageLog[]

  @@index([slug])
}

enum Plan {
  TRIAL
  GROWTH
  PRO
  BUSINESS
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & MEMBERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  avatar        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships           OrganizationMember[]
  assignedConversations Conversation[]       @relation("AssignedAgent")
  sentMessages          Message[]            @relation("SentByUser")
  sessions              UserSession[]
  verificationTokens    VerificationToken[]
  passwordResets        PasswordReset[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(AGENT)
  isActive       Boolean    @default(true)
  invitedAt      DateTime   @default(now())
  joinedAt       DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMembers  TeamMember[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

enum MemberRole {
  ADMIN
  AGENT
  CAMPAIGN_MANAGER
  TEMPLATE_MANAGER
  AUTOMATION_MANAGER
  BILLING_MANAGER
}

model Invitation {
  id             String     @id @default(cuid())
  organizationId String
  email          String
  role           MemberRole @default(AGENT)
  token          String     @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime   @default(now())

  @@index([organizationId])
  @@index([token])
}

// ─────────────────────────────────────────────────────────────────────────────
// TEAMS
// ─────────────────────────────────────────────────────────────────────────────

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  conversations Conversation[] @relation("AssignedTeam")

  @@index([organizationId])
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  memberId String

  team   Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WHATSAPP ACCOUNTS
// ─────────────────────────────────────────────────────────────────────────────

model WhatsappAccount {
  id             String   @id @default(cuid())
  organizationId String
  phoneNumber    String
  phoneNumberId  String
  displayName    String
  wabaId         String
  accessToken    String   @db.Text
  webhookSecret  String?
  isActive       Boolean  @default(true)
  qualityRating  String?
  messagingLimit String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  broadcasts    Broadcast[]

  @@index([organizationId])
  @@index([phoneNumber])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTACTS
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  phone          String
  name           String?
  email          String?
  avatar         String?
  stage          ContactStage @default(LEAD)
  isBlocked      Boolean      @default(false)
  optedOut       Boolean      @default(false)
  lastSeenAt     DateTime?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attributes   ContactAttribute[]
  tags         ContactTag[]
  conversations Conversation[]
  broadcastLogs BroadcastRecipient[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([phone])
}

enum ContactStage {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
}

model ContactAttribute {
  id        String @id @default(cuid())
  contactId String
  key       String
  value     String @db.Text

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, key])
  @@index([contactId])
}

model ContactTag {
  id        String @id @default(cuid())
  contactId String
  tag       String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, tag])
  @@index([contactId])
}

// ─────────────────────────────────────────────────────────────────────────────
// LABELS
// ─────────────────────────────────────────────────────────────────────────────

model Label {
  id             String @id @default(cuid())
  organizationId String
  name           String
  color          String @default("#6366f1")

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations ConversationLabel[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVERSATIONS & MESSAGES
// ─────────────────────────────────────────────────────────────────────────────

model Conversation {
  id                String             @id @default(cuid())
  organizationId    String
  whatsappAccountId String
  contactId         String
  assignedAgentId   String?
  assignedTeamId    String?
  status            ConversationStatus @default(OPEN)
  channel           Channel            @default(WHATSAPP)
  isRead            Boolean            @default(false)
  lastMessageAt     DateTime?
  sessionExpiresAt  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount     @relation(fields: [whatsappAccountId], references: [id])
  contact         Contact             @relation(fields: [contactId], references: [id])
  assignedAgent   User?               @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  assignedTeam    Team?               @relation("AssignedTeam", fields: [assignedTeamId], references: [id])
  messages        Message[]
  labels          ConversationLabel[]
  notes           ConversationNote[]

  @@index([organizationId])
  @@index([contactId])
  @@index([whatsappAccountId])
  @@index([assignedAgentId])
  @@index([assignedTeamId])
  @@index([status])
  @@index([lastMessageAt])
}

enum ConversationStatus {
  OPEN
  RESOLVED
  PENDING
  SNOOZED
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBSITE
}

model ConversationLabel {
  id             String @id @default(cuid())
  conversationId String
  labelId        String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label        Label        @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([conversationId, labelId])
  @@index([conversationId])
}

model ConversationNote {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String?
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  organizationId String
  wamid          String?       @unique
  direction      Direction
  type           MessageType   @default(TEXT)
  status         MessageStatus @default(SENT)
  content        String?       @db.Text
  mediaUrl       String?
  mediaType      String?
  mediaCaption   String?
  templateName   String?
  templateData   Json?
  interactive    Json?
  sentByUserId   String?
  isBotMessage   Boolean       @default(false)
  failureReason  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser   User?        @relation("SentByUser", fields: [sentByUserId], references: [id])

  @@index([conversationId])
  @@index([organizationId])
  @@index([wamid])
  @@index([createdAt])
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACTS
  TEMPLATE
  INTERACTIVE
  REACTION
  SYSTEM
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// MESSAGE TEMPLATES
// ─────────────────────────────────────────────────────────────────────────────

model MessageTemplate {
  id              String           @id @default(cuid())
  organizationId  String
  name            String
  category        TemplateCategory
  language        String           @default("en")
  status          TemplateStatus   @default(DRAFT)
  metaTemplateId  String?
  headerType      String?
  headerContent   String?
  body            String           @db.Text
  footer          String?
  buttons         Json?
  rejectionReason String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  broadcasts   Broadcast[]

  @@unique([organizationId, name, language])
  @@index([organizationId])
  @@index([status])
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  DELETED
  PAUSED
}

// ─────────────────────────────────────────────────────────────────────────────
// BROADCASTS / CAMPAIGNS
// ─────────────────────────────────────────────────────────────────────────────

model Broadcast {
  id                String          @id @default(cuid())
  organizationId    String
  whatsappAccountId String
  templateId        String?
  name              String
  status            BroadcastStatus @default(DRAFT)
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  totalCount        Int             @default(0)
  sentCount         Int             @default(0)
  deliveredCount    Int             @default(0)
  readCount         Int             @default(0)
  failedCount       Int             @default(0)
  repliedCount      Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount      @relation(fields: [whatsappAccountId], references: [id])
  template        MessageTemplate?     @relation(fields: [templateId], references: [id])
  recipients      BroadcastRecipient[]

  @@index([organizationId])
  @@index([status])
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  PAUSED
  FAILED
}

model BroadcastRecipient {
  id          String        @id @default(cuid())
  broadcastId String
  contactId   String
  variables   Json?
  status      MessageStatus @default(PENDING)
  wamid       String?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failReason  String?
  createdAt   DateTime      @default(now())

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id])

  @@index([broadcastId])
  @@index([contactId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// CHATBOTS (Flow Builder)
// ─────────────────────────────────────────────────────────────────────────────

model Chatbot {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean     @default(false)
  triggerType    TriggerType @default(KEYWORD)
  triggerValue   String?
  nodes          Json        @default("[]")
  edges          Json        @default("[]")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions     ChatbotSession[]

  @@index([organizationId])
}

enum TriggerType {
  KEYWORD
  NEW_CONVERSATION
  ANY_MESSAGE
  TEMPLATE_RECEIVED
  INBOUND_AD
}

model ChatbotSession {
  id            String    @id @default(cuid())
  chatbotId     String
  contactId     String
  currentNodeId String?
  variables     Json      @default("{}")
  isActive      Boolean   @default(true)
  startedAt     DateTime  @default(now())
  endedAt       DateTime?

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
  @@index([contactId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RULE-BASED AUTOMATION
// ─────────────────────────────────────────────────────────────────────────────

model Automation {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  isActive       Boolean         @default(true)
  triggerEvent   AutomationEvent
  conditions     Json            @default("[]")
  actions        Json            @default("[]")
  runCount       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum AutomationEvent {
  MESSAGE_RECEIVED
  CONVERSATION_CREATED
  CONVERSATION_ASSIGNED
  CONVERSATION_RESOLVED
  CONTACT_CREATED
  CONTACT_UPDATED
  BROADCAST_REPLIED
}

// ─────────────────────────────────────────────────────────────────────────────
// QUICK REPLIES
// ─────────────────────────────────────────────────────────────────────────────

model QuickReply {
  id             String   @id @default(cuid())
  organizationId String
  shortcut       String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, shortcut])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// API KEYS & WEBHOOKS
// ─────────────────────────────────────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  keyPrefix      String
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WebhookEndpoint {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  url             String
  secret          String?
  events          Json      @default("[]")
  isActive        Boolean   @default(true)
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id                String   @id @default(cuid())
  webhookEndpointId String
  event             String
  payload           Json
  statusCode        Int?
  responseBody      String?  @db.Text
  success           Boolean  @default(false)
  duration          Int?
  createdAt         DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING & SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @unique
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  plan                   Plan               @default(TRIAL)
  status                 SubscriptionStatus @default(TRIALING)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  automationTriggersUsed Int                @default(0)
  apiCallsUsed           Int                @default(0)
  aiCreditsUsed          Int                @default(0)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ─────────────────────────────────────────────────────────────────────────────
// USAGE LOGS
// ─────────────────────────────────────────────────────────────────────────────

model UsageLog {
  id             String    @id @default(cuid())
  organizationId String
  type           UsageType
  quantity       Int       @default(1)
  metadata       Json?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
  @@index([createdAt])
}

enum UsageType {
  MESSAGE_SENT
  MESSAGE_RECEIVED
  BROADCAST_SENT
  AUTOMATION_TRIGGER
  API_CALL
  AI_CREDIT
  CHATBOT_SESSION
}

// ─────────────────────────────────────────────────────────────────────────────
// PLAN CONFIG (Admin-managed pricing plans)
// ─────────────────────────────────────────────────────────────────────────────

model PlanConfig {
  id                 String   @id @default(cuid())
  name               String   @unique
  slug               String   @unique
  description        String?
  monthlyPrice       Float    @default(0)
  annualPrice        Float    @default(0)
  currency           String   @default("USD")
  isActive           Boolean  @default(true)
  isPopular          Boolean  @default(false)
  sortOrder          Int      @default(0)
  maxUsers           Int      @default(1)
  maxBroadcasts      Int      @default(500)
  maxAutomations     Int      @default(100)
  maxApiCalls        Int      @default(1000)
  maxAiCredits       Int      @default(50)
  maxWhatsappNumbers Int      @default(1)
  features           Json     @default("[]")
  stripePriceMonthly String?
  stripePriceAnnual  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
